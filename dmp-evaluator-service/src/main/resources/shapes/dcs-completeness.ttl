@prefix val: <https://w3id.org/validation/ns/core#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix dcso: <https://w3id.org/dcso/ns/core#>.
@prefix terms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

val:DMPCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:DMP ;
    sh:property [
                    sh:path dcso:hasContact ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:hasDataset ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:created ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:hasId ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:ethicalIssuesExist ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:language ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:modified ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                sh:path terms:title ;
                sh:minCount 1 ;
                ] .



val:ContactCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Contact ;
    sh:property [
                    sh:path dcso:hasContactId ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path foaf:mbox ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path foaf:name ;
                    sh:minCount 1 ;
                ] .



val:IdCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Id ;
    sh:property [
                    sh:path dcso:identifier ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:identifierType ;
                    sh:minCount 1 ;
                ] .



val:ContributorCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Contributor ;
    sh:property [
                    sh:path dcso:hasContributorId ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path foaf:name ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:role ;
                    sh:minCount 1 ;
                ] .



val:CostCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Cost ;
    sh:property [
                    sh:path terms:title ;
                    sh:minCount 1 ;
                ] .



val:DatasetCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Dataset ;
    sh:property [
                    sh:path dcso:hasDatasetId ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:personalData ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:sensitiveData ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path terms:title ;
                    sh:minCount 1 ;
                ] .


val:DistributionCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Distribution ;
    sh:property [
                    sh:path dcso:dataAccess ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path terms:title ;
                    sh:minCount 1 ;
                ] .



val:FundingCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Funding ;
    sh:property [
                    sh:path dcso:hasId ;
                    sh:minCount 1 ;
                ] .



val:HostCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Host ;
    sh:property [
                    sh:path terms:title ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:url ;
                    sh:minCount 1 ;
                ] .



val:LicenseCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:License ;
    sh:property [
                    sh:path dcso:licenseRef ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:startDate ;
                    sh:minCount 1 ;
                ] .



val:MetadataCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Metadata ;
    sh:property [
                    sh:path dcso:language ;
                    sh:minCount 1 ;
                ] ;
    sh:property [
                    sh:path dcso:hasMetadataStandardId ;
                    sh:minCount 1 ;
                ] .



val:ProjectCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:Metadata ;
    sh:property [
                    sh:path terms:title ;
                    sh:minCount 1 ;
                ] .



val:SecurityAndPrivacyCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:SecurityPrivacy ;
    sh:property [
                    sh:path terms:title ;
                    sh:minCount 1 ;
                ] .



val:TechnicalResourceCompletenessShape a sh:NodeShape ;
    sh:targetClass dcso:TechnicalResource ;
    sh:property [
                    sh:path foaf:name ;
                    sh:minCount 1 ;
                ] .